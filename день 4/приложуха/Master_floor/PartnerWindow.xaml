<Window x:Class="Master_floor.PartnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Данные партнера" Height="350" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Наименование партнера:"/>
        <TextBox x:Name="tbName" Margin="0,5,0,10"/>
        
        <TextBlock Text="Тип партнера (ООО, ЗАО...):"/>
        <TextBox x:Name="tbType" Margin="0,5,0,10"/>
        
        <TextBlock Text="ФИО Директора:"/>
        <TextBox x:Name="tbDirector" Margin="0,5,0,10"/>
        
        <TextBlock Text="Рейтинг:"/>
        <TextBox x:Name="tbRating" Margin="0,5,0,10"/>

        <UniformGrid Columns="2" Margin="0,10,0,0">
            <Button Content="Сохранить" Click="btnSave_Click" Height="30" Margin="5"/>
            <Button Content="Отмена" IsCancel="True" Height="30" Margin="5"/>
        </UniformGrid>
    </StackPanel>
</Window>